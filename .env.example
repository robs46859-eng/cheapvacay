# Server
PORT=3000
NODE_ENV=development

# Logging & ops (optional)
LOG_LEVEL=debug
# SENTRY_DSN=https://...@o....ingest.sentry.io/...
# Rate limits (defaults match server/config.ts)
# API_RATE_LIMIT_MAX=400
# API_RATE_LIMIT_WINDOW_MS=900000
# QUOTE_RATE_LIMIT_MAX=40
# QUOTE_RATE_LIMIT_WINDOW_MS=3600000

# Gemini (optional — falls back to static advice if unset). Name is GEMINI_API_KEY (not GEMINIAPIKEY).
GEMINI_API_KEY=

# Amadeus (optional — modeled costs if unset)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Firebase Admin (backend) — pick ONE:
# 1) Paste the full service account JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# 2) Or point to a file (local dev):
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# Firebase web app (Vite client) — from Firebase console → Project settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:xxxx:web:xxxx

# App Check (reCAPTCHA v3) — register the web app in Firebase Console → App Check
VITE_APPCHECK_RECAPTCHA_SITE_KEY=
# Local only: set a debug token from App Check “Manage debug tokens” (optional)
# VITE_APPCHECK_DEBUG_TOKEN=

# Server: enforce App Check (default: on in production, off in dev). Set to true to test enforcement locally.
# APPCHECK_ENFORCE=false

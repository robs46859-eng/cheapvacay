{
  "project": "cheapvacay",
  "service": {
    "renderServiceName": "cheapvacay-app"
  },
  "environments": {
    "local": {
      "description": "Developer machine"
    },
    "staging": {
      "description": "Render staging"
    },
    "production": {
      "description": "Render production"
    }
  },
  "variables": {
    "PORT": {
      "kind": "config",
      "description": "HTTP port for the Express server",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "3000",
        "staging": "10000",
        "production": "10000"
      },
      "renderSync": true
    },
    "NODE_ENV": {
      "kind": "config",
      "description": "Node runtime environment",
      "requiredIn": ["staging", "production"],
      "defaults": {
        "local": "development",
        "staging": "production",
        "production": "production"
      },
      "allowedValues": ["development", "staging", "production"],
      "renderSync": true
    },
    "GEMINI_API_KEY": {
      "kind": "secret",
      "description": "Google Gemini API key for AI travel tips (env name GEMINI_API_KEY; not GEMINIAPIKEY)",
      "requiredIn": [],
      "renderSync": true
    },
    "AMADEUS_CLIENT_ID": {
      "kind": "secret",
      "description": "Amadeus API client ID (optional)",
      "requiredIn": [],
      "renderSync": true
    },
    "AMADEUS_CLIENT_SECRET": {
      "kind": "secret",
      "description": "Amadeus API client secret (optional)",
      "requiredIn": [],
      "renderSync": true
    },
    "SENTRY_DSN": {
      "kind": "secret",
      "description": "Sentry DSN for server error reporting (optional; omit if not using Sentry)",
      "requiredIn": [],
      "renderSync": false
    },
    "LOG_LEVEL": {
      "kind": "config",
      "description": "Pino log level: fatal | error | warn | info | debug | trace",
      "requiredIn": [],
      "defaults": {
        "local": "debug",
        "staging": "info",
        "production": "info"
      },
      "renderSync": true
    },
    "API_RATE_LIMIT_MAX": {
      "kind": "config",
      "description": "Max /api requests per IP per window (general limiter)",
      "requiredIn": [],
      "defaults": {
        "local": "400",
        "staging": "400",
        "production": "400"
      },
      "renderSync": true
    },
    "API_RATE_LIMIT_WINDOW_MS": {
      "kind": "config",
      "description": "Window size in ms for general API rate limit",
      "requiredIn": [],
      "defaults": {
        "local": "900000",
        "staging": "900000",
        "production": "900000"
      },
      "renderSync": true
    },
    "QUOTE_RATE_LIMIT_MAX": {
      "kind": "config",
      "description": "Max POST /planner/quote requests per IP per window",
      "requiredIn": [],
      "defaults": {
        "local": "40",
        "staging": "40",
        "production": "40"
      },
      "renderSync": true
    },
    "QUOTE_RATE_LIMIT_WINDOW_MS": {
      "kind": "config",
      "description": "Window size in ms for quote endpoint rate limit",
      "requiredIn": [],
      "defaults": {
        "local": "3600000",
        "staging": "3600000",
        "production": "3600000"
      },
      "renderSync": true
    },
    "FIREBASE_SERVICE_ACCOUNT": {
      "kind": "secret",
      "description": "Firebase service account JSON string for Admin SDK (Firestore + token verify). Alternative: set GOOGLE_APPLICATION_CREDENTIALS to a file path.",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "VITE_FIREBASE_API_KEY": {
      "kind": "config",
      "description": "Firebase web API key (embedded in client bundle)",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "VITE_FIREBASE_AUTH_DOMAIN": {
      "kind": "config",
      "description": "Firebase authDomain (e.g. project.firebaseapp.com)",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "VITE_FIREBASE_PROJECT_ID": {
      "kind": "config",
      "description": "Firebase / GCP project ID",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "VITE_FIREBASE_APP_ID": {
      "kind": "config",
      "description": "Firebase web app ID",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "VITE_APPCHECK_RECAPTCHA_SITE_KEY": {
      "kind": "config",
      "description": "reCAPTCHA v3 site key from Firebase App Check (baked in at Vite build time)",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "APPCHECK_ENFORCE": {
      "kind": "config",
      "description": "Set false to skip App Check verification (not recommended; use only for local debugging)",
      "requiredIn": [],
      "renderSync": true
    }
  }
}

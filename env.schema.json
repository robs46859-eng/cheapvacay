{
  "project": "cheapvacay",
  "service": {
    "renderServiceName": "cheapvacay-app"
  },
  "environments": {
    "local": {
      "description": "Developer machine with mock data"
    },
    "staging": {
      "description": "Render staging with live Gemini AI integration"
    },
    "production": {
      "description": "Render production"
    }
  },
  "variables": {
    "PORT": {
      "kind": "config",
      "description": "HTTP port for the Express server",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "3000",
        "staging": "10000",
        "production": "10000"
      },
      "renderSync": true
    },
    "NODE_ENV": {
      "kind": "config",
      "description": "Node runtime environment",
      "requiredIn": ["staging", "production"],
      "defaults": {
        "local": "development",
        "staging": "production",
        "production": "production"
      },
      "allowedValues": ["development", "staging", "production"],
      "renderSync": true
    },
    "GEMINI_API_KEY": {
      "kind": "secret",
      "description": "Google Gemini API key for AI travel planning features",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "FIREBASE_PROJECT_ID": {
      "kind": "config",
      "description": "Firebase project ID (optional — Firebase scaffolded but excluded from launch slice)",
      "requiredIn": [],
      "renderSync": false
    },
    "FIREBASE_API_KEY": {
      "kind": "secret",
      "description": "Firebase web API key (optional — for future Firebase auth integration)",
      "requiredIn": [],
      "renderSync": false
    }
  }
}
